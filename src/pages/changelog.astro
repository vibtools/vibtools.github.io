---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import PageHero from '@/components/PageHero.astro';
import { formatDate } from '@/lib/format';

const entries = (await getCollection('changelog')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
const renderedEntries = await Promise.all(
  entries.map(async (entry) => ({ entry, rendered: await render(entry) })),
);
---

<BaseLayout
  title="Changelog"
  description="Changelog for the VibTools open-source developer hub."
  canonicalPath="/changelog/"
  type="article"
  breadcrumbs={[
    { name: 'Home', url: 'https://vibtools.github.io/' },
    { name: 'Changelog', url: 'https://vibtools.github.io/changelog/' },
  ]}
>
  <PageHero
    eyebrow="Changelog"
    title="Website changelog"
    description="Auditable changes to the official VibTools open-source developer hub."
  />
  <Container class="py-14 sm:py-18">
    <div class="space-y-8">
      {
        renderedEntries.map(({ entry, rendered: { Content } }) => (
          <article class="rounded-xl border border-border bg-surface p-6 sm:p-8">
            <div class="flex flex-col gap-3 border-b border-border pb-5 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-mono text-xs text-secondary">{formatDate(entry.data.publishedAt)}</p>
                <h2 class="mt-2 text-2xl font-bold text-text-primary">{entry.data.title}</h2>
                <p class="mt-2 text-sm text-text-secondary">{entry.data.summary}</p>
              </div>
              <span class="w-fit rounded-full border border-border bg-background px-3 py-1 font-mono text-xs text-text-primary">
                {entry.data.version}
              </span>
            </div>
            <div class="prose-vib mt-6">
              <Content />
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</BaseLayout>
