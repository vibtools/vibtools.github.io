---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import PageHero from '@/components/PageHero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getProjects } from '@/lib/github';

const projects = await getProjects();
const tools = projects.filter((project) => project.slug !== 'vibtools-open-source-hub');
---

<BaseLayout
  title="Developer Tools"
  description="Developer-facing tools in the VibTools open-source ecosystem."
  canonicalPath="/tools/"
  breadcrumbs={[
    { name: 'Home', url: 'https://vibtools.github.io/' },
    { name: 'Developer Tools', url: 'https://vibtools.github.io/tools/' },
  ]}
>
  <PageHero
    eyebrow="Developer tools"
    title="Developer-facing VibTools software"
    description="Desktop, server, and identity projects that support technical workflows and self-hosted deployments."
  />
  <Container class="py-14 sm:py-18">
    <section aria-labelledby="tools-list-title">
      <h2 id="tools-list-title" class="sr-only">All VibTools developer tools</h2>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {tools.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </Container>
</BaseLayout>
