---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {
    eyebrow && (
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-secondary">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-2xl font-bold tracking-tight text-text-primary sm:text-3xl">{title}</h2>
  {description && <p class="mt-4 text-base text-text-secondary sm:text-lg">{description}</p>}
</header>
